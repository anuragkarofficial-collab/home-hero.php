$hero_after_image = get_field('hero_after_image');

$get_image_data = function($image, $fallback_alt = '') {
  if (is_array($image)) {
    return array(
      'url' => isset($image['url']) ? $image['url'] : '',
      'alt' => !empty($image['alt']) ? $image['alt'] : $fallback_alt,
    );
  }

  if (is_numeric($image)) {
    return array(
      'url' => wp_get_attachment_image_url($image, 'full'),
      'alt' => get_post_meta($image, '_wp_attachment_image_alt', true) ?: $fallback_alt,
    );
  }

  if (is_string($image) && !empty($image)) {
    return array(
      'url' => $image,
      'alt' => $fallback_alt,
    );
  }

  return array(
    'url' => '',
    'alt' => $fallback_alt,
  );
};

$before_image = $get_image_data($hero_before_image, 'Before image');
$after_image = $get_image_data($hero_after_image, 'After image');

$hero_title_html = nl2br(esc_html($hero_title));
if (trim($hero_title) === 'Sharper Images. Faster Scans. Higher ROI.') {
  $hero_title_html = 'Sharper Images.<br>Faster Scans. Higher ROI.';
}

/*
 * NEW: Build compare tabs data from repeater
 */
$compare_items = array();

if (have_rows('hero_compare_tabs')) {
  while (have_rows('hero_compare_tabs')) {
    the_row();

    $row_before_image = $get_image_data(get_sub_field('before_image'), 'Before image');
    $row_after_image  = $get_image_data(get_sub_field('after_image'), 'After image');

    if (!empty($row_before_image['url']) && !empty($row_after_image['url'])) {
      $compare_items[] = array(
        'tab_name'           => get_sub_field('tab_name') ?: 'Tab',
        'before_image_url'   => $row_before_image['url'],
        'before_image_alt'   => $row_before_image['alt'],
        'after_image_url'    => $row_after_image['url'],
        'after_image_alt'    => $row_after_image['alt'],
        'compare_badge_text' => get_sub_field('compare_badge_text') ?: $hero_comparison_badge_text,
        'before_label'       => get_sub_field('before_label') ?: $hero_before_label,
        'after_label'        => get_sub_field('after_label') ?: $hero_after_label,
        'product_chip_text'  => get_sub_field('product_chip_text') ?: $hero_product_chip_text,
      );
    }
  }
}

/*
 * Fallback to old single before/after fields if repeater is empty
 */
if (empty($compare_items) && !empty($before_image['url']) && !empty($after_image['url'])) {
  $compare_items[] = array(
