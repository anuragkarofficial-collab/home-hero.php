<script>
  document.addEventListener('DOMContentLoaded', function () {
    var hero = document.querySelector('[data-home-hero-v2]');
    if (!hero) return;

    document.body.classList.add('transparent', 'home-test-hero-active');

    function updateHeaderScrollState() {
      if (window.scrollY > 20) {
        document.body.classList.add('home-test-header-scrolled');
      } else {
        document.body.classList.remove('home-test-header-scrolled');
      }
    }

    updateHeaderScrollState();
    window.addEventListener('scroll', updateHeaderScrollState, { passive: true });

    var heroShell = hero.querySelector('.hc-hero-shell');
    var heroCopy = hero.querySelector('.hc-hero-copy');
    var heroVisual = hero.querySelector('.hc-hero-visual');
    var buttons = hero.querySelector('.hc-buttons');
    var title = hero.querySelector('.hc-title');

    var buttonsOriginalParent = buttons ? buttons.parentNode : null;
    var buttonsOriginalNextSibling = buttons ? buttons.nextSibling : null;
    var originalTitleHtml = title ? title.innerHTML : '';

    function escapeHtml(str) {
      return str
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#039;');
    }

    function getTitleLinesFromHtml(html) {
      var temp = document.createElement('div');
      temp.innerHTML = html;
      var text = (temp.textContent || temp.innerText || '').replace(/\s+/g, ' ').trim();

      if (!text) return [];

      var parts = text.match(/[^.!?]+[.!?]?/g) || [];
      return parts
        .map(function (part) {
          return part.replace(/\s+/g, ' ').trim();
        })
        .filter(function (part) {
          return part.length > 0;
        });
    }

    function updateMobileHeroLayout() {
      var isMobile = window.innerWidth <= 767;

      if (isMobile) {
        if (buttons && heroVisual && buttons.parentNode !== heroShell) {
          heroVisual.insertAdjacentElement('afterend', buttons);
        }

        if (title && originalTitleHtml) {
          var lines = getTitleLinesFromHtml(originalTitleHtml);

          if (lines.length === 3) {
            title.innerHTML = lines.map(function (line) {
              return '<span class="hc-title-line">' + escapeHtml(line) + '</span>';
            }).join('');
          } else {
            title.innerHTML = originalTitleHtml;
          }
        }
      } else {
        if (buttons && buttonsOriginalParent && buttons.parentNode !== buttonsOriginalParent) {
          if (buttonsOriginalNextSibling && buttonsOriginalNextSibling.parentNode === buttonsOriginalParent) {
            buttonsOriginalParent.insertBefore(buttons, buttonsOriginalNextSibling);
          } else {
            buttonsOriginalParent.appendChild(buttons);
          }
        }

        if (title && title.innerHTML !== originalTitleHtml) {
          title.innerHTML = originalTitleHtml;
        }
      }
    }

    updateMobileHeroLayout();
    window.addEventListener('resize', updateMobileHeroLayout);

    var compareItems = <?php echo wp_json_encode($compare_items); ?>;
    var compare = hero.querySelector('[data-compare]');

    if (compare) {
      var input = compare.querySelector('.hc-compare-input');
      var beforeImage = compare.querySelector('[data-compare-before]');
      var afterImage = compare.querySelector('[data-compare-after]');
      var badge = compare.querySelector('[data-compare-badge]');
      var beforeLabel = compare.querySelector('[data-compare-before-label]');
      var afterLabel = compare.querySelector('[data-compare-after-label]');
      var chip = compare.querySelector('[data-compare-chip]');
      var tabButtons = hero.querySelectorAll('[data-compare-tab-index]');

      var currentIndex = 0;
      var autoTabDelay = 5000;
      var autoTabTimer = null;

      function updateSplit(value) {
        compare.style.setProperty('--split', value + '%');
        if (input) input.value = value;
      }

      function startTabProgress(activeIndex) {
        tabButtons.forEach(function (button, index) {
          button.classList.remove('is-playing');
          button.style.setProperty('--hc-tab-duration', autoTabDelay + 'ms');
          void button.offsetWidth;
          if (index === activeIndex) {
            button.classList.add('is-playing');
          }
        });
      }

      function applyCompareItem(index) {
        if (!compareItems[index]) return;

        currentIndex = index;
        var item = compareItems[index];

        if (beforeImage) {
          beforeImage.src = item.before_image_url || '';
          beforeImage.alt = item.before_image_alt || '';
        }

        if (afterImage) {
          afterImage.src = item.after_image_url || '';
          afterImage.alt = item.after_image_alt || '';
        }

        if (badge) {
          badge.innerHTML = (item.compare_badge_text || '').replace(/\s+\+/g, '<br>+');
        }

        if (beforeLabel) {
          beforeLabel.textContent = item.before_label || '';
        }

        if (afterLabel) {
          afterLabel.textContent = item.after_label || '';
        }

        if (chip) {
          chip.textContent = item.product_chip_text || '';
        }

        tabButtons.forEach(function (button) {
          var isActive = parseInt(button.getAttribute('data-compare-tab-index'), 10) === index;
          button.classList.toggle('is-active', isActive);
        });

        startTabProgress(index);
      }

      function scheduleNextTab() {
        if (autoTabTimer) {
          clearTimeout(autoTabTimer);
        }

        if (compareItems.length <= 1) return;

        autoTabTimer = setTimeout(function () {
          var nextIndex = (currentIndex + 1) % compareItems.length;
          applyCompareItem(nextIndex);
          scheduleNextTab();
        }, autoTabDelay);
      }

      if (input) {
        input.addEventListener('input', function () {
          updateSplit(this.value);
        });

        input.addEventListener('change', function () {
          updateSplit(this.value);
        });
      }

      tabButtons.forEach(function (button) {
        button.addEventListener('click', function () {
          var index = parseInt(this.getAttribute('data-compare-tab-index'), 10);
          applyCompareItem(index);
          scheduleNextTab();
        });
      });

      updateSplit(54);
      applyCompareItem(0);
      scheduleNextTab();
    }

    var primaryCta = hero.querySelector('.hc-btn-primary');
    var secondaryCta = hero.querySelector('.hc-btn-secondary');
    var ctaFollowTimer = null;
    var ctaVisibilityTriggered = false;
    var prefersReducedMotion = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function restartAnimationClass(element, className) {
      if (!element) return;
      element.classList.remove(className);
      void element.offsetWidth;
      element.classList.add(className);
    }

    function runCtaSequence() {
      if (prefersReducedMotion || !primaryCta) return;

      primaryCta.classList.remove('is-cta-scanning');
      if (secondaryCta) {
        secondaryCta.classList.remove('is-cta-follow');
      }

      restartAnimationClass(primaryCta, 'is-cta-scanning');

      if (secondaryCta) {
        if (ctaFollowTimer) clearTimeout(ctaFollowTimer);

        ctaFollowTimer = setTimeout(function () {
          restartAnimationClass(secondaryCta, 'is-cta-follow');
        }, 2750);
      }
    }

    if (!prefersReducedMotion && primaryCta) {
      if ('IntersectionObserver' in window) {
        var heroObserver = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting && entry.intersectionRatio >= 0.45) {
              if (!ctaVisibilityTriggered) {
                ctaVisibilityTriggered = true;
                runCtaSequence();
              }
            } else {
              ctaVisibilityTriggered = false;
            }
          });
        }, {
          threshold: [0, 0.45, 0.7]
        });

        heroObserver.observe(hero);
      } else {
        setTimeout(runCtaSequence, 900);
      }

      window.addEventListener('pageshow', function (event) {
        if (event.persisted) {
          setTimeout(runCtaSequence, 250);
        }
      });
    }

    if (window.gsap) {
      var revealItems = hero.querySelectorAll('[data-hero-item]');
      gsap.from(revealItems, {
        y: 28,
        opacity: 0,
        duration: 0.85,
        stagger: 0.12,
        ease: 'power3.out',
        delay: 0.05
      });

      var media = hero.querySelector('[data-hero-media]');
      if (media) {
        gsap.from(media, {
          x: 20,
          opacity: 0,
          duration: 0.95,
          ease: 'power3.out',
          delay: 0.1
        });
      }
    }
  });
</script>
